# Virtual environment
venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Datasets and derived files (large; not source code)
data/HDFS_v1/
data/BGL/
data/*.csv
data/*.npz

# OS junk
.DS_Store
Thumbs.db

# Editor settings
.vscode/
.idea/

@"

# Raw dataset archives (re-downloadable from LogHub)
data/*.zip

# Model checkpoints (large; can be regenerated by re-training)
results/*.pt
"@ | Add-Content -Path .gitignore -Encoding utf8
